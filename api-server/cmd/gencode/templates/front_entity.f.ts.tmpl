import { request } from "@/utils/http/request";
import type { $ENTITY_NAME$ } from "./$ENTITY_LINE$.d";
import { $ENTITY_NAME$Fields } from './$ENTITY_LINE$.f';
import { SearchUtils } from "@/utils/dataTable/search";
import type { Extra } from '@/utils/where/extra';
import type {  DataTableEntityConfig } from '@/components/admin/dataTable/dataTable.d';

//实体配置
export const $ENTITY_NAME$EntityConfig:DataTableEntityConfig = {
  entityName: '$ENTITY_NAME$',//实体名称
  entityLineName: '$ENTITY_LINE$',//实体行下划线命名
  entityTitle: '$ENTITY_TITLE$',//实体标题
  parentFolderName: '$PARENT_DIR_PREFIX$',//父级目录
}

/**
 * $ENTITY_NAME$ 服务类
 * 提供$ENTITY_TITLE$相关的 CRUD 操作和列表搜索
 */
export class $ENTITY_NAME$Service {

  /**
   * 创建$ENTITY_TITLE$
   */
  static create<T = $ENTITY_NAME$>(data: object): Promise<T> {
    return request.post<T>("api$PARENT_DIR_PREFIX$/$ENTITY_LINE$/create", data);
  }

  /**
   * 更新$ENTITY_TITLE$
   */
  static update<T = $ENTITY_NAME$>(id: number, data: object): Promise<T> {
    return request.post<T>("api$PARENT_DIR_PREFIX$/$ENTITY_LINE$/update", {
      id,
      update_data: data,
      update_fields: $ENTITY_NAME$Fields.getUpdateFields() // 空数组表示自动更新非零值,传入视为要避免0值不生效的问题

    });
  }

  /**

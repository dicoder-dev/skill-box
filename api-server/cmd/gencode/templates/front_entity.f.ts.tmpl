   */
  static async findById<T = $ENTITY_NAME$>(id: number): Promise<T> {
    return request.post<T>("api$PARENT_DIR_PREFIX$/$ENTITY_LINE$/find_by_id", { id });
  }

  /**
   * 搜索$ENTITY_TITLE$列表

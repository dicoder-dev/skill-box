   */
  static async search$ENTITY_NAME$List(
    searchData: Record<string, unknown>,
    extra: Extra
  ): Promise<{ list: $ENTITY_NAME$[], total: number }> {
    const where = SearchUtils.formatSearchParams(
      searchData,
      $ENTITY_NAME$Fields.list(),
      extra
    );

    const result = await SearchUtils.getList<$ENTITY_NAME$>("api$PARENT_DIR_PREFIX$/$ENTITY_LINE$/search", where);
    return {
      list: result.list,
      total: result.total
    };
  }
}

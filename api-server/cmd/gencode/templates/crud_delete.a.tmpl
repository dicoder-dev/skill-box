package c$PACKAGE_NAME$

import (
	"ginp-api/internal/app/gapi/dto/comdto"
	"ginp-api/internal/app/gapi/service/$PARENT_DIR$s$PACKAGE_NAME$"
	"ginp-api/pkg/ginp"
)


func init() {
	//API init: 删除 $ENTITY_TITLE$
	ginp.RouterAppend(ginp.RouterItem{
		Path:           "/api$PARENT_DIR_PREFIX$/$ENTITY_LINE$/delete",                //api路径
		AliasePaths:    []string{},                                                     //别名路径
		Handler:        ginp.BindParamsHandler(Delete, &comdto.ReqDelete{}),           //对应控制器
		ParamTypes:     []interface{}{&comdto.ReqDelete{}},                            //参数类型（自动提取到SwaggerInfo.RequestParams）
		HttpType:       ginp.HttpPost,                                                  //http请求类型
		NeedLogin:      true,                                                           //是否需要登录
		NeedPermission: true,                                                           //是否需要鉴权
		PermissionName: "$ENTITY_LINE$.delete",                                        //完整的权限名称,会跟权限表匹配
		OperationType:  ginp.OpDelete,                                                  //操作类型
		Swagger: &ginp.SwaggerInfo{
			Title:       "删除$ENTITY_TITLE$",
			Description: "",
			// RequestParams 会自动从 ParamTypes[0] 提取
		},
	})
}

func Delete(ctx *ginp.ContextPlus, params *comdto.ReqDelete) error {
	//也可以自己创建并传入读写db: tables.New$ENTITY_NAME$(wdb,rdb)
	err := s$PACKAGE_NAME$.Model().DeleteById(params.ID)
	if err != nil {
		return err
	}
	return nil
}



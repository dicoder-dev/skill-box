package c$PACKAGE_NAME$

import (
	"ginp-api/internal/gapi/dto/comdto"
	"ginp-api/internal/gapi/service/$PARENT_DIR$s$PACKAGE_NAME$"
	"ginp-api/pkg/ginp"
	"ginp-api/pkg/where"
)



func init() {
	// API init: 搜索$ENTITY_TITLE$"
	ginp.RouterAppend(ginp.RouterItem{
		Path:           "/api$PARENT_DIR_PREFIX$/$ENTITY_LINE$/search",                //api路径
		AliasePaths:    []string{},                                                     //别名路径
		Handler:        ginp.BindParamsHandler(Search, &comdto.ReqSearch{}),           //对应控制器
		ParamTypes:     []interface{}{&comdto.ReqSearch{}},                            //参数类型（自动提取到SwaggerInfo.RequestParams）
		HttpType:       ginp.HttpPost,                                                  //http请求类型
		NeedLogin:      false,                                                          //是否需要登录
		NeedPermission: false,                                                          //是否需要鉴权
		PermissionName: "$ENTITY_LINE$.search",                                        //完整的权限名称,会跟权限表匹配
		OperationType:  ginp.OpSearch,                                                  //操作类型
		Swagger: &ginp.SwaggerInfo{
			Title:       "搜索$ENTITY_TITLE$",
			Description: "",
			// RequestParams 会自动从 ParamTypes[0] 提取
		},
	})
}

func Search(ctx *ginp.ContextPlus, params *comdto.ReqSearch) error {
	if err := where.Check(params.Wheres); err != nil {
		return err
	}
	//也可以自己创建并传入读写db: tables.New$ENTITY_NAME$(wdb,rdb)
	list, total, err := s$PACKAGE_NAME$.Model().FindListWithRelations(params.Wheres, params.Extra, params.Relations)
	if err != nil {
		return err
	}

	resp := &comdto.RespSearch{
		List:     list,
		Total:    uint(total),
		PageNum:  uint(params.Extra.PageNum),
		PageSize: uint(params.Extra.PageSize),
	}
	ctx.SuccessData(resp)
	return nil
}



